# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=regiobuild
POSTGRES_USER=regiobuild
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+psycopg2://regiobuild:change_me@postgres:5432/regiobuild

# --- Vector store ---
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=rngp_requirements
VECTOR_BACKEND=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=regiobuild_normative
QDRANT_API_KEY=
# chroma — только локально с requirements-legacy-chroma.txt
# VECTOR_BACKEND=chroma
DEPLOY_PROFILE=bothost-demo

# --- Embeddings ---
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_MODEL_ENTERPRISE=intfloat/multilingual-e5-large
RERANKER_MODEL=

# --- LLM provider ---
# one of: gigachat | yandexgpt
LLM_PROVIDER=gigachat
LLM_LIGHT_PROVIDER=gigachat

# GigaChat (https://developers.sber.ru/portal/products/gigachat-api)
GIGACHAT_CREDENTIALS=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat-2-Pro
GIGACHAT_VERIFY_SSL_CERTS=false

# YandexGPT (https://yandex.cloud/ru/docs/foundation-models/)
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_MODEL=yandexgpt/latest

# --- Telegram bot ---
TELEGRAM_BOT_TOKEN=

# --- Backend ---
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://api:8000

# --- Misc ---
LOG_LEVEL=INFO
DAILY_QUERY_LIMIT=30
LOG_JSON=false
LLM_CACHE_ENABLED=true
LLM_CACHE_SIZE=256
SENTRY_DSN=

# --- Grafana Cloud (не коммитить токены) ---
GRAFANA_CLOUD_PROMETHEUS_URL=
GRAFANA_CLOUD_PROMETHEUS_USER=
GRAFANA_CLOUD_PROMETHEUS_TOKEN=

# --- Bothost only ---
# переключает роль внутри общего Dockerfile (см. entrypoint.sh): api | bot
SERVICE_ROLE=api
