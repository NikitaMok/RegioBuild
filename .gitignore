# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/

# секреты — в git только .env.example
.env
.env.*
!.env.example
*.env.local
bothost-*.env
*credentials*
*secrets*

# сырые/промежуточные данные пайплайна
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
data/backups/
!data/curated/
!data/curated/**
data/structured/*
!data/structured/.gitkeep
!data/structured/_summary.json
data/raw/docs_list.txt

# DB
*.db
*.sqlite3
llm_cache.json
**/llm_cache.json

# IDE / локальные настройки редактора
