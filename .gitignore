# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/

# Env / secrets — в git только шаблон .env.example, всё остальное с
# реальными токенами/кредами остаётся локально (включая bothost-*.env
# для панели хостинга и любые .env.* копии).
.env
.env.*
!.env.example
*.env.local
bothost-*.env
*credentials*
*secrets*

# Data artifacts (регенерируются локально пайплайном, в git не нужны —
# кроме готового Chroma-индекса и классификатора, см. блок исключений внизу)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# DB
*.db
*.sqlite3

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Jupyter
.ipynb_checkpoints/

# Готовый Chroma-индекс и обученный классификатор коммитим осознанно (правила
# ниже переопределяют исключения выше, включая *.db/*.sqlite3 — сам Chroma
# хранит свой индекс в chroma.sqlite3): на дешёвом хостинге типа Bothost
# гонять скрейпинг+эмбеддинги на сервере накладно и ненадёжно (нет гарантий
# по RAM и доступности сайтов с нормативов с другого IP), а сам индекс
# небольшой — пара десятков МБ на 7 тыс. чанков. Пересобирать локально после
# любого изменения нормативов и коммитить заново.
!data/chroma/
!data/chroma/**
!app/classifier/artifacts/
!app/classifier/artifacts/**
